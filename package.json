{
  "name": "judiciary-hackwarts",
  "version": "1.0.0",
  "description": "Unified runner for Judiciary HackWarts",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend && cd backend && python3 -m venv .venv && ./.venv/bin/pip install -r requirements.txt",
    "frontend": "npm run dev --prefix frontend",
    "backend": "cd backend && ./start-dev.sh",
    "dev": "concurrently --kill-others \"npm run frontend\" \"npm run backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
